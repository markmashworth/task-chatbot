# JIRA Cloud configuration
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token_here

# GitHub configuration
GITHUB_TOKEN=your_github_personal_access_token_here

# OpenAI configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2

# Server
PORT=8080
# Allowed CORS origin. Set to your frontend URL in production.
CORS_ORIGIN=http://localhost:3000

# Optional: map display names to JIRA emails and GitHub usernames.
# Without this, the app falls back to API search (reasonable for Jira, much less reliable for GitHub).
# Format: JSON object keyed by the name people use in conversation.
# USER_MAP={"John":{"jira":"john.smith@company.com","github":"jsmith"},"Sarah":{"jira":"sarah.jones@company.com","github":"sjones"}}
